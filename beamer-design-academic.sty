% ============================================================
%  beamer-design-academic.sty — default academic visual profile
% ============================================================
\ProvidesPackage{beamer-design-academic}

\beamerstyle@metropolistrue
\usetheme{metropolis}

\definecolor{AcademicAccent}{HTML}{005A9C}
\definecolor{AcademicText}{HTML}{2B2B2B}
\definecolor{AcademicBackground}{HTML}{FAFAFA}

\setbeamercolor{progress bar}{fg=AcademicAccent}
\setbeamercolor{title separator}{fg=AcademicAccent}
\setbeamercolor{structure}{fg=AcademicAccent}
\setbeamercolor{normal text}{fg=AcademicText,bg=AcademicBackground}
\setbeamercolor{alerted text}{fg=AcademicAccent}
\setbeamercolor{example text}{fg=AcademicAccent!60!black}
\setbeamercolor{frametitle}{fg=white,bg=AcademicText}

\endinput
