% ============================================================
%  beamer-design-classic.sty — formal, institutional profile
% ============================================================
\ProvidesPackage{beamer-design-classic}

\beamerstyle@metropolisfalse
\usetheme{Madrid}

\definecolor{ClassicAccent}{HTML}{174A7E}
\definecolor{ClassicDark}{HTML}{12345A}
\definecolor{ClassicBackground}{HTML}{F7F9FC}

\setbeamercolor{structure}{fg=ClassicAccent}
\setbeamercolor{normal text}{fg=black,bg=ClassicBackground}
\setbeamercolor{alerted text}{fg=ClassicDark}
\setbeamercolor{example text}{fg=ClassicAccent!70!black}
\setbeamercolor{palette primary}{fg=white,bg=ClassicDark}
\setbeamercolor{palette secondary}{fg=white,bg=ClassicAccent}
\setbeamercolor{palette tertiary}{fg=white,bg=ClassicDark}
\setbeamercolor{frametitle}{fg=white,bg=ClassicDark}
\setbeamercolor{title}{fg=ClassicDark}

\endinput
