% ============================================================
%  beamer-design-midnight.sty — dark technical-talk profile
% ============================================================
\ProvidesPackage{beamer-design-midnight}

\beamerstyle@metropolistrue
\usetheme{metropolis}

\definecolor{MidnightAccent}{HTML}{66D9EF}
\definecolor{MidnightText}{HTML}{F4F7FB}
\definecolor{MidnightMuted}{HTML}{B8C4D5}
\definecolor{MidnightBackground}{HTML}{111827}
\definecolor{MidnightFrame}{HTML}{1F2937}

\setbeamercolor{progress bar}{fg=MidnightAccent}
\setbeamercolor{title separator}{fg=MidnightAccent}
\setbeamercolor{structure}{fg=MidnightAccent}
\setbeamercolor{normal text}{fg=MidnightText,bg=MidnightBackground}
\setbeamercolor{background canvas}{bg=MidnightBackground}
\setbeamercolor{title}{fg=MidnightText}
\setbeamercolor{subtitle}{fg=MidnightMuted}
\setbeamercolor{author}{fg=MidnightMuted}
\setbeamercolor{institute}{fg=MidnightMuted}
\setbeamercolor{date}{fg=MidnightMuted}
\setbeamercolor{alerted text}{fg=MidnightAccent}
\setbeamercolor{example text}{fg=MidnightAccent}
\setbeamercolor{frametitle}{fg=MidnightText,bg=MidnightFrame}
\setbeamercolor{block title}{fg=MidnightBackground,bg=MidnightAccent}
\setbeamercolor{block body}{fg=MidnightText,bg=MidnightFrame}
\setbeamercolor{block title alerted}{fg=MidnightBackground,bg=MidnightAccent!85!red}
\setbeamercolor{block body alerted}{fg=MidnightText,bg=MidnightFrame}
\setbeamercolor{block title example}{fg=MidnightBackground,bg=MidnightAccent!80!green}
\setbeamercolor{block body example}{fg=MidnightText,bg=MidnightFrame}

\endinput
