# latexmk configuration for Beamer + XeLaTeX
$pdf_mode = 5;          # Use xelatex (pdf_mode=5 → xelatex)
$pdf_previewer = 'open -a Skim';  # Optional: PDF viewer on macOS
$clean_ext = 'aux bbl bcf blg fdb_latexmk fls glg glo gls idx ilg ind ist lof log lot nav out run.xml snm synctex.gz toc vrb xdv';
$silent = 0;            # Show compiler output (set to 1 for quiet mode)
